{
  "outputDirectory": "dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/api/growth-agent-sync", "schedule": "0 2 * * *" },
    { "path": "/api/growth-agent-ads-sync", "schedule": "30 2 * * *" },
    { "path": "/api/growth-agent-diagnose", "schedule": "0 3 * * *" }
  ]
}
